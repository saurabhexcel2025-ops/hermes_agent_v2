# ═══════════════════════════════════════════════
# Hermes — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════

# ── Ollama Cloud (https://ollama.com/settings) ──
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_LLM_MODEL=glm-5
# Other available models: kimi-k2.6, qwen3.5

# ── Control Hub ──
CONTROL_HUB_PORT=42069
NEXT_PUBLIC_APP_URL=http://localhost:42069

# ── Mem0 ──
MEM0_USER_ID=hermes-user
