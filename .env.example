# ═══════════════════════════════════════════════
# Hermes — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════

# ── Ollama Cloud (https://ollama.com/settings) ──
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_LLM_MODEL=glm-5
# Other available models: kimi-k2.6, qwen3.5

# ── Domain (nginx + certbot) ──
DOMAIN=mc.spacearmour.io

# ── Control Hub ──
NEXT_PUBLIC_APP_URL=https://mc.spacearmour.io

# ── Control Hub Auth (generate with: openssl rand -hex 32) ──
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ── Mem0 ──
MEM0_USER_ID=hermes-user

# ── Hermes Gateway (API server on port 8642) ──
# Set these in ~/.hermes/.env on the host (NOT in Docker .env):
#   API_SERVER_ENABLED=true
#   API_SERVER_KEY=<openssl rand -hex 32>
#   API_SERVER_HOST=0.0.0.0
#   GATEWAY_ALLOW_ALL_USERS=true
