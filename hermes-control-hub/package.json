{

  "name": "control-hub",

  "version": "0.1.0",

  "private": true,

  "scripts": {

    "dev": "next dev",

    "dev:network": "next dev -H 0.0.0.0",

    "prebuild": "node scripts/tooling/prebuild-db.mjs",

    "db:migrate": "node scripts/tooling/migrate-db.mjs",

    "db:seed": "npx tsx scripts/tooling/import-hermes-state.ts && npx tsx scripts/tooling/seed-catalog.ts --merge",

    "build": "next build",

    "start": "next start",

    "lint": "eslint . --max-warnings 0",

    "start:network": "next start -H 0.0.0.0",

    "test": "jest",

    "test:watch": "jest --watch",

    "test:coverage": "jest --coverage",

    "test:e2e": "cross-env PORT=3000 playwright test",

    "test:full-install": "python tests/integration/test_full_install_update_process.py --profile smoke --skip-http",

    "test:full-install-release": "python tests/integration/test_full_install_update_process.py --profile release --skip-http",

    "test:full-install-hermes": "python tests/integration/test_full_install_update_process.py --profile release --skip-http --with-real-hermes-install",

    "test:docker-deploy-smoke": "bash tests/scripts/docker-deploy-api-smoke.sh",

    "discover-hermes": "node scripts/tooling/discover-agents.mjs",

    "generate:schema-json": "npx tsx scripts/tooling/generate-json-schema.ts",

    "seed-pack": "node scripts/tooling/generate-seed-pack.mjs"

  },

  "dependencies": {

    "@radix-ui/react-dialog": "^1.1.15",

    "@radix-ui/react-dropdown-menu": "^2.1.16",

    "@radix-ui/react-tabs": "^1.1.13",

    "@types/bcryptjs": "^2.4.6",

    "@types/js-yaml": "^4.0.9",

    "@types/pg": "^8.20.0",

    "bcryptjs": "^3.0.3",

    "better-sqlite3": "^12.8.0",

    "class-variance-authority": "^0.7.1",

    "clsx": "^2.1.1",

    "jose": "^6.2.3",

    "js-yaml": "^4.1.1",

    "lucide-react": "^1.7.0",

    "next": "16.2.3",

    "pg": "^8.21.0",

    "react": "19.2.4",

    "react-dom": "19.2.4",

    "tailwind-merge": "^3.5.0",

    "zod": "^4.3.6"

  },

  "devDependencies": {

    "@playwright/test": "^1.59.1",

    "@tailwindcss/postcss": "^4",

    "@testing-library/jest-dom": "^6.9.1",

    "@testing-library/react": "^16.3.2",

    "@types/better-sqlite3": "^7.6.13",

    "@types/jest": "^30.0.0",

    "@types/node": "^20",

    "@types/react": "^19",

    "@types/react-dom": "^19",

    "cross-env": "^7.0.3",

    "eslint": "^9",

    "eslint-config-next": "16.2.3",

    "jest": "^30.3.0",

    "jest-environment-jsdom": "^30.3.0",

    "tailwindcss": "^4",

    "ts-jest": "^29.4.9",

    "tsx": "^4.21.0",

    "typescript": "^5"

  },

  "pnpm": {

    "onlyBuiltDependencies": [

      "better-sqlite3",

      "esbuild",

      "sharp",

      "unrs-resolver"

    ]

  },

  "overrides": {

    "@typescript-eslint/typescript-estree": {

      "brace-expansion": "5.0.4"

    },

    "glob": {

      "brace-expansion": "2.0.2"

    },

    "minimatch@3.1.5": {

      "brace-expansion": "1.1.14"

    }

  }

}

