# Optional Control Hub server tuning (copy to .env.local for Next.js)

# TCP port for Next.js (setup.sh defaults to first free 42069–42100, or set explicitly).

# PORT=42069



# Hermes install root — config, cron, sessions, profiles (default ~/.hermes)

# Agent package: {HERMES_HOME}/hermes-agent/ (Nous Hermes installer)

# HERMES_HOME=/home/you/.hermes



# Hardware cron: Control Hub–managed scripts/logs (default under CH_DATA_DIR).

# CH_SCRIPTS_DIR=/home/you/control-hub/data/scripts

# CH_HARDWARE_LOG_DIR=/home/you/control-hub/data/logs



# Hindsight JSON backup (scripts/hardware/ch-backup.sh — optional overrides)

# HINDSIGHT_BACKUP_DIR=/home/you/.hermes/backups/hindsight

# HINDSIGHT_BACKUP_BANK=hermes

# HINDSIGHT_BACKUP_RETENTION_DAYS=30

# HINDSIGHT_BACKUP_LIMIT=999999



# Control Hub JSON data root (missions, templates, operations, stories).

# Default: $HOME/control-hub/data (matches nested Hermes cron mission updates).

# CH_DATA_DIR=/home/you/control-hub/data

# (alias) CONTROL_HUB_DATA_DIR=



# Comma-separated extra dev origins for next.config (include host + port per URL).

# scripts/bootstrap/setup.sh writes this for LAN `next dev` (HMR). Override only if needed.

# CH_ALLOWED_DEV_ORIGINS=http://127.0.0.1:42069,http://192.168.1.10:42069



# Block all writes (GET still works)

# CH_READ_ONLY=1



# ── Deploy / Update ────────────────────────────────────────────────
# Enable POST /api/update (rebuild, restart, update from git).
# Default: true (allow rebuild/restart from the UI).
CH_ENABLE_DEPLOY_API=true

# Git branch for deploy/update API and ch-deploy (default dev)

# CH_UPDATE_GIT_BRANCH=main

# Professional catalog: data/seed/ → SQLite (CH_DATA_DIR) → HERMES_HOME/profiles/<slug>/
# npm run db:seed (also run by setup.sh and ch-deploy update)

# bootstrap/install.sh (non-interactive): optional copy missing SOUL.md/AGENTS.md from data/seed/profiles/
# INSTALL_HERMES_PROFILE_TEMPLATES=yes

# ch-deploy restart: Next bind host (default 0.0.0.0 — same as npm run start:network / Docker).
# Optional socat relay: public port → loopback:PORT (no LAN IP required — listens on 0.0.0.0).
# CH_SOCAT_RELAY=yes
# CH_SOCAT_RELAY_PORT=42069
# CH_NEXT_BIND_HOST=127.0.0.1
# Optional: bind relay to one interface IP instead of all (0.0.0.0).
# CH_SOCAT_BIND=192.168.1.169



