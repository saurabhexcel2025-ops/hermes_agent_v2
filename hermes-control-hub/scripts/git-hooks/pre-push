#!/bin/bash
# Pre-push hook — prevents direct pushes to main
protected_branch="main"
while read local_ref local_oid remote_ref remote_oid; do
    branch=$(echo "$remote_ref" | sed 's|refs/heads/||')
    if [ "$branch" = "$protected_branch" ]; then
        commit_msg=$(git log -1 --format=%s "$local_oid" 2>/dev/null)
        if echo "$commit_msg" | grep -qiE "^(Merge|merge)"; then
            echo "✓ Merge commit to main — allowed"
        else
            echo ""
            echo "╔══════════════════════════════════════════╗"
            echo "║  BLOCKED: Direct push to main            ║"
            echo "╚══════════════════════════════════════════╝"
            echo ""
            echo "Push to dev or a feature branch instead."
            echo "Create a PR to merge to main."
            echo ""
            exit 1
        fi
    fi
done
exit 0
